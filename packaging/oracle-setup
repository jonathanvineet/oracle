#!/bin/bash

# ORACLE Widget Setup Script
# Creates Übersicht widget and configures it with your Android device's Tailscale IP

set -e

echo ""
echo "🎬 ORACLE Widget Setup"
echo "====================="
echo ""

# Check if Übersicht is installed
if ! [ -d "/Applications/Übersicht.app" ]; then
  echo "❌ Übersicht not found. Please install it first:"
  echo ""
  echo "   brew install uebersicht"
  echo ""
  exit 1
fi

# Get Tailscale IP
echo "Enter your Android device's Tailscale IP address:"
echo "(Find it by running: adb shell 'ip address show' on your Mac)"
echo "Format: 100.x.x.x"
echo ""
read -p "> " TAILSCALE_IP

# Validate IP format
if ! [[ $TAILSCALE_IP =~ ^100\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo ""
  echo "❌ Invalid Tailscale IP format. Should be 100.x.x.x"
  exit 1
fi

# Create widget directory
WIDGET_DIR="$HOME/Library/Application Support/Übersicht/widgets/oracle.widget"
mkdir -p "$WIDGET_DIR"

# Create widget file
cat > "$WIDGET_DIR/index.jsx" << 'WIDGET_EOF'
export const refreshFrequency = false;

export const className = `
  top: 30px;
  right: 30px;
  width: 360px;
  height: 240px;
  background: rgba(15,15,15,0.7);
  backdrop-filter: blur(20px);
  border-radius: 18px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0,0,0,0.45);
  border: 1px solid rgba(255,255,255,0.08);
`;

const STREAM_URL = "STREAM_URL_PLACEHOLDER";

export const render = () => {
  return `
    <div style="
      width:100%;
      height:100%;
      position:relative;
      background:#000;
    ">
      <img
        src="${STREAM_URL}"
        style="
          width:100%;
          height:100%;
          object-fit:cover;
        "
        onload="this.style.opacity=1"
      />

      <div style="
        position:absolute;
        top:10px;
        left:10px;
        background:rgba(0,0,0,0.6);
        padding:6px 10px;
        border-radius:10px;
        color:#06b6d4;
        font-family:monospace;
        font-size:12px;
        letter-spacing:1px;
        font-weight:bold;
      ">
        🎬 ORACLE LIVE
      </div>
    </div>
  `;
};
WIDGET_EOF

# Replace placeholder with actual IP
sed -i.bak "s|STREAM_URL_PLACEHOLDER|http://${TAILSCALE_IP}:8080/video|g" "$WIDGET_DIR/index.jsx"
rm "$WIDGET_DIR/index.jsx.bak"

# Save config
CONFIG_DIR="$HOME/.oracle"
mkdir -p "$CONFIG_DIR"
cat > "$CONFIG_DIR/config.json" << EOF
{
  "streamUrl": "http://${TAILSCALE_IP}:8080/video",
  "setupDate": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

echo ""
echo "✅ Widget created successfully!"
echo ""
echo "📍 Location: $WIDGET_DIR/index.jsx"
echo "⚙️  Config: $CONFIG_DIR/config.json"
echo ""
echo "📋 Android Setup Checklist:"
echo "   ☐ Install IP Webcam from Google Play"
echo "   ☐ Install Tailscale from Google Play"
echo "   ☐ Open IP Webcam and set port to 8080"
echo "   ☐ Tap 'Start server' (green Stop button visible)"
echo "   ☐ Verify Tailscale is connected"
echo ""
echo "🎬 Now open Übersicht:"
echo "   1. Press ⌘Space"
echo "   2. Type 'Übersicht'"
echo "   3. Press Enter"
echo "   4. Widget appears top-right corner"
echo ""
echo "🔧 To reconfigure, run this script again."
echo ""
