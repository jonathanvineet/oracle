#!/bin/bash

# Oracle Widget Setup Script
# Installs and configures the ORACLE Übersicht widget

set -e

CONFIG_DIR="$HOME/.oracle"
CONFIG_FILE="$CONFIG_DIR/config.json"
UEBERSICHT_WIDGETS="$HOME/Library/Application Support/Übersicht/widgets"
WIDGET_SOURCE="${BASH_SOURCE%/*}/widget"

echo "🎬 ORACLE Widget Setup"
echo "======================"
echo ""

# Check if Übersicht is installed
if ! command -v open &> /dev/null || ! [ -d "/Applications/Übersicht.app" ]; then
  echo "❌ Übersicht not found. Please install it first:"
  echo "   brew install uebersicht"
  exit 1
fi

# Create config directory
mkdir -p "$CONFIG_DIR"

# Check if config already exists
if [ -f "$CONFIG_FILE" ]; then
  echo "Found existing config at: $CONFIG_FILE"
  read -p "Do you want to update it? (y/n) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Using existing config."
    exit 0
  fi
fi

# Get Tailscale IP
echo ""
echo "Enter your Android device's Tailscale IP address (100.x.x.x):"
read -p "> " TAILSCALE_IP

# Validate IP format
if ! [[ $TAILSCALE_IP =~ ^100\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  echo "❌ Invalid Tailscale IP format. Should be 100.x.x.x"
  exit 1
fi

# Get optional password
echo ""
echo "Enter stream password (leave empty for 'oracle123'):"
read -p "> " STREAM_PASSWORD
STREAM_PASSWORD=${STREAM_PASSWORD:-oracle123}

# Create config file
mkdir -p "$(dirname "$CONFIG_FILE")"
cat > "$CONFIG_FILE" << EOF
{
  "streamUrl": "http://$TAILSCALE_IP:8080/video",
  "password": "$STREAM_PASSWORD",
  "refreshInterval": 5000,
  "setupDate": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF

echo ""
echo "✅ Configuration saved to: $CONFIG_FILE"
echo ""

# Install widget
if [ -d "$UEBERSICHT_WIDGETS" ]; then
  WIDGET_DEST="$UEBERSICHT_WIDGETS/oracle"
  
  # Backup existing widget if present
  if [ -d "$WIDGET_DEST" ]; then
    echo "Backing up existing widget..."
    mv "$WIDGET_DEST" "$WIDGET_DEST.backup"
  fi
  
  # Copy widget files
  cp -r "$WIDGET_SOURCE" "$WIDGET_DEST"
  echo "✅ Widget installed to: $WIDGET_DEST"
else
  echo "⚠️  Übersicht widgets directory not found."
  echo "   Please manually copy the widget to your Übersicht widgets folder"
fi

echo ""
echo "🎬 Setup complete!"
echo ""
echo "Next steps:"
echo "1. Open Übersicht (⌘Space and type 'Übersicht')"
echo "2. The ORACLE widget should appear on your desktop"
echo "3. Make sure your Android device is streaming"
echo ""
echo "To reconfigure, run: oracle-widget setup"
echo "To view config, run:   oracle-widget config"
