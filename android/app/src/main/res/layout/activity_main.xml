<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1724"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ORACLE"
                android:textColor="#06B6D4"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <!-- Status indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_status_pill"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_red"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IDLE"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- Camera preview -->
        <androidx.camera.view.PreviewView
            android:id="@+id/cameraPreview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0"
            android:minHeight="220dp"
            android:background="#000000"
            app:scaleType="fillCenter"
            android:layout_marginBottom="20dp" />

        <!-- Stream URL card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_cyan"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡  STREAM URL"
                android:textColor="#06B6D4"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvStreamUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="http://?.?.?.?:8080/stream"
                android:textColor="#00FF88"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:background="@drawable/bg_code"
                android:padding="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap URL to copy · Open in Mac browser to test"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Stats card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FPS"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvFps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— FPS"
                    android:textColor="#06B6D4"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="14dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PORT"
                    android:textColor="#6B7280"
                    android:textSize="10sp"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8080"
                    android:textColor="#06B6D4"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- Start/Stop button -->
        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶ Start Streaming"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:background="@drawable/bg_btn_cyan"
            android:layout_marginBottom="16dp" />

        <!-- Instructions (shown when idle) -->
        <TextView
            android:id="@+id/tvInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Tap Start Streaming\n2. Copy the URL above\n3. Put it in ~/.oracle/config.json on your Mac\n4. Open the Übersicht widget — done"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:background="@drawable/bg_card"
            android:padding="16dp" />

    </LinearLayout>
</ScrollView>
